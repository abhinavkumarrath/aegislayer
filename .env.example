# AegisLayer — Environment Configuration
# ========================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM API Configuration ────────────────────────────────────────────────────
# RECOMMENDED (FREE — no credit card required):
# 1. Go to https://console.groq.com
# 2. Create a free account
# 3. Go to API Keys → Create API Key
# 4. Copy the key (starts with gsk_...) and paste below
LLM_API_KEY=USE_YOUR_GROQ_API_HERE

# Groq (fastest free inference)
LLM_BASE_URL=https://api.groq.com/openai/v1

# Alternatives:
# OpenAI:       https://api.openai.com/v1
# Fireworks AI: https://api.fireworks.ai/inference/v1
# LMStudio:     http://localhost:1234/v1

# Default model
LLM_MODEL=llama-3.3-70b-versatile

# Groq free models (as of 2026):
#   llama-3.3-70b-versatile              (best quality, recommended)
#   llama-3.1-8b-instant                 (fastest)
#   meta-llama/llama-4-scout-17b-16e-instruct  (llama 4, fast)
#   gemma2-9b-it                         (google, efficient)

# LLM request timeout in seconds
LLM_TIMEOUT_S=30

# Maximum tokens to generate in the LLM response
LLM_MAX_TOKENS=2048

# ── NER Engine Configuration ─────────────────────────────────────────────────
# HuggingFace model for NER (must support token-classification pipeline)
# Default: dslim/bert-base-NER  (English, fast, ~400MB)
# Alternatives:
#   dslim/bert-large-NER        (higher accuracy, ~1.2GB)
#   Jean-Baptiste/roberta-large-ner-english  (best accuracy, ~1.4GB)
#   davlan/bert-base-multilingual-cased-ner-hrl  (multilingual)
NER_MODEL=dslim/bert-base-NER

# Minimum confidence score for NER detections (0.0-1.0)
# Lower = more aggressive redaction (more false positives)
# Higher = more conservative (may miss some entities)
NER_SCORE_THRESHOLD=0.75

# Timeout for NER processing
NER_REQUEST_TIMEOUT_S=45.0

# ── Server Configuration ──────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
ENV_MODE=development

# ── AMD ROCm / GPU Notes ─────────────────────────────────────────────────────
# AegisLayer automatically detects ROCm via torch.cuda.is_available().
# On AMD GPU pods, PyTorch with ROCm support exposes the GPU as a CUDA device.
# No additional configuration is needed — the NER engine auto-selects the GPU.
#
# To install PyTorch with ROCm 6.0 support:
#   pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/rocm6.0
#
# Verify your device:
#   python -c "import torch; print(torch.cuda.get_device_name(0))"
